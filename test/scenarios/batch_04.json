{
  "_doc": "Batch 4 — 50 distinct, bulk operation scenarios. Each is a unique transformation.",
  "scenarios": [
    {"id": "151", "description": "cp -R tree of 3 dirs, verify", "setup": ["mkdir -p {vfs}/src/A/B {vfs}/src/C", "touch {vfs}/src/A/file1 {vfs}/src/A/B/file2 {vfs}/src/C/file3", "mkdir {vfs}/dst", "cp -R {vfs}/src {vfs}/dst/"], "verify": ["exists {vfs}/dst/src/A/B/file2", "exists {vfs}/dst/src/C/file3"]},
    {"id": "152", "description": "rm -R non-empty tree", "setup": ["mkdir -p {vfs}/kill/A/B", "touch {vfs}/kill/A/x {vfs}/kill/A/B/y", "rm -R {vfs}/kill"], "verify": ["not exists {vfs}/kill"]},
    {"id": "153", "description": "find all files in tree, count", "setup": ["mkdir -p {vfs}/search", "for i in $(seq 1 16); do touch {vfs}/search/f$i; done"], "verify": ["match test $(find {vfs}/search -type f | wc -l) -eq 16"]},
    {"id": "154", "description": "Copy 8 corpus files into one dir", "setup": ["for f in src_pdf_small src_pdf_large src_zip src_dmg src_xlsx src_yaml src_json src_pdf1; do cp $(eval echo \\$$f) {vfs}/; done"], "verify": ["count {vfs} == 8"]},
    {"id": "155", "description": "Bulk create 24 empty files, count", "setup": ["for i in $(seq 1 24); do touch {vfs}/b$i; done"], "verify": ["count {vfs} == 24"]},
    {"id": "156", "description": "Bulk create 12 dirs, count", "setup": ["for i in $(seq 1 12); do mkdir {vfs}/d$i; done"], "verify": ["count {vfs} == 12"]},
    {"id": "157", "description": "cp -R then delete source", "setup": ["mkdir -p {vfs}/source/sub", "touch {vfs}/source/sub/file", "cp -R {vfs}/source {vfs}/copy_target/", "rm -R {vfs}/source"], "verify": ["exists {vfs}/copy_target/source/sub/file", "not exists {vfs}/source"]},
    {"id": "158", "description": "Bulk write 6 files with content, verify all readable", "setup": ["for i in 1 2 3 4 5 6; do echo $i > {vfs}/f$i; done", "match test \"$(cat {vfs}/f1 | tr -d '\\n')\" = '1'"], "verify": ["exists {vfs}/f1", "exists {vfs}/f6"]},
    {"id": "159", "description": "Find all dirs in tree (should include intermediate)", "setup": ["mkdir -p {vfs}/a/b/c/d", "match test $(find {vfs}/a -type d | wc -l) -eq 4"], "verify": ["exists {vfs}/a/b/c/d"]},
    {"id": "160", "description": "Bulk rename files with mv loop", "setup": ["for i in 1 2 3 4 5; do touch {vfs}/old$i; done", "for i in 1 2 3 4 5; do mv {vfs}/old$i {vfs}/new$i; done"], "verify": ["not exists {vfs}/old1", "exists {vfs}/new1", "count {vfs} == 5"]},
    {"id": "161", "description": "cp -R entire subtree to nested location", "setup": ["mkdir -p {vfs}/top/inner", "touch {vfs}/top/inner/file", "mkdir -p {vfs}/dst1/dst2", "cp -R {vfs}/top {vfs}/dst1/dst2/"], "verify": ["exists {vfs}/dst1/dst2/top/inner/file"]},
    {"id": "162", "description": "Find files by name pattern", "setup": ["mkdir {vfs}/patterns", "touch {vfs}/patterns/a.txt {vfs}/patterns/b.md {vfs}/patterns/c.txt"], "verify": ["match test $(find {vfs}/patterns -name '*.txt' | wc -l) -eq 2"]},
    {"id": "163", "description": "Bulk create, then bulk delete via rm *", "setup": ["for i in $(seq 1 16); do touch {vfs}/z$i; done", "rm {vfs}/z*"], "verify": ["count {vfs} == 0"]},
    {"id": "164", "description": "Create 4 dirs, copy same file into each, all MD5 match", "setup": ["for d in a b c d; do mkdir {vfs}/$d; cp {src_pdf_small} {vfs}/$d/file; done"], "verify": ["md5 {vfs}/a/file == src_pdf_small", "md5 {vfs}/b/file == src_pdf_small", "md5 {vfs}/c/file == src_pdf_small", "md5 {vfs}/d/file == src_pdf_small"]},
    {"id": "165", "description": "rmdir on non-empty dir fails, dir remains", "setup": ["mkdir {vfs}/nonempty", "touch {vfs}/nonempty/x", "rmdir {vfs}/nonempty || true"], "verify": ["exists {vfs}/nonempty", "exists {vfs}/nonempty/x"]},
    {"id": "166", "description": "Copy tree, modify copies, originals untouched", "setup": ["mkdir -p {vfs}/orig/tree", "touch {vfs}/orig/tree/file", "cp -R {vfs}/orig {vfs}/modified/", "echo new > {vfs}/modified/orig/tree/file"], "verify": ["match test \"$(cat {vfs}/orig/tree/file)\" != 'new'"]},
    {"id": "167", "description": "Count files after bulk operations", "setup": ["mkdir {vfs}/c", "for i in $(seq 1 20); do touch {vfs}/c/f$i; done", "rm {vfs}/c/f1 {vfs}/c/f3 {vfs}/c/f5"], "verify": ["count {vfs}/c == 17"]},
    {"id": "168", "description": "find with -name on nested", "setup": ["mkdir -p {vfs}/proj/src/main {vfs}/proj/src/test", "touch {vfs}/proj/src/main/a.c {vfs}/proj/src/test/b.c {vfs}/proj/src/main/c.h"], "verify": ["match test $(find {vfs}/proj -name '*.c' | wc -l) -eq 2"]},
    {"id": "169", "description": "Bulk mkdir -p mixed depth", "setup": ["mkdir -p {vfs}/mix/{a/{x,y},b/{z,w},c}"], "verify": ["exists {vfs}/mix/a/x", "exists {vfs}/mix/a/y", "exists {vfs}/mix/b/z", "exists {vfs}/mix/b/w", "exists {vfs}/mix/c"]},
    {"id": "170", "description": "Bulk cp multiple files at once (shell expansion)", "setup": ["mkdir {vfs}/srcs", "cp {src_pdf_small} {src_pdf_large} {src_zip} {vfs}/srcs/"], "verify": ["count {vfs}/srcs == 3"]},
    {"id": "171", "description": "Create then find -empty", "setup": ["touch {vfs}/empty1 {vfs}/empty2", "echo content > {vfs}/nonempty"], "verify": ["match test $(find {vfs}/ -maxdepth 1 -type f -empty | wc -l) -eq 2"]},
    {"id": "172", "description": "Move all files from one dir to another", "setup": ["mkdir {vfs}/from {vfs}/to", "for i in 1 2 3 4; do touch {vfs}/from/f$i; done", "mv {vfs}/from/* {vfs}/to/"], "verify": ["count {vfs}/to == 4", "count {vfs}/from == 0"]},
    {"id": "173", "description": "cp -R into existing dir merges content", "setup": ["mkdir {vfs}/existing", "touch {vfs}/existing/existing_file", "mkdir -p {vfs}/src/A", "touch {vfs}/src/A/new_file", "cp -R {vfs}/src/A {vfs}/existing/"], "verify": ["exists {vfs}/existing/A/new_file", "exists {vfs}/existing/existing_file"]},
    {"id": "174", "description": "Bulk delete specific pattern", "setup": ["mkdir {vfs}/keep {vfs}/kill", "touch {vfs}/keep/a {vfs}/keep/b {vfs}/kill/a {vfs}/kill/b {vfs}/kill/c", "rm {vfs}/kill/*"], "verify": ["count {vfs}/keep == 2", "count {vfs}/kill == 0"]},
    {"id": "175", "description": "Find dirs matching pattern", "setup": ["mkdir -p {vfs}/node_modules/a {vfs}/node_modules/b {vfs}/src", "match test $(find {vfs}/ -maxdepth 1 -name 'node_modules' | wc -l) -eq 1"], "verify": ["exists {vfs}/node_modules/a"]},
    {"id": "176", "description": "Bulk copy all PDFs in dir", "setup": ["mkdir {vfs}/pdfs", "for f in /Users/bogdanadnan/Downloads/*.pdf; do cp \"$f\" {vfs}/pdfs/ 2>/dev/null; done"], "verify": ["match test $(ls {vfs}/pdfs/ | wc -l) -ge 5"]},
    {"id": "177", "description": "Count files in nested structure", "setup": ["mkdir -p {vfs}/d1/d2/d3", "for d in d1 d1/d2 d1/d2/d3; do for i in 1 2; do touch {vfs}/$d/f$i; done; done"], "verify": ["match test $(find {vfs}/d1 -type f | wc -l) -eq 6"]},
    {"id": "178", "description": "Copy with trailing slash on destination", "setup": ["mkdir {vfs}/dst/", "cp {src_pdf_small} {vfs}/dst/"], "verify": ["exists {vfs}/dst/181854127_Plata_GhiseulRo.pdf"]},
    {"id": "179", "description": "Bulk rename files in dir", "setup": ["for i in $(seq 1 8); do touch {vfs}/temp$i; done", "for i in $(seq 1 8); do mv {vfs}/temp$i {vfs}/final$i; done"], "verify": ["count {vfs} == 8", "not exists {vfs}/temp1"]},
    {"id": "180", "description": "Recursive ls to verify structure", "setup": ["mkdir -p {vfs}/tree/sub1/sub2", "touch {vfs}/tree/a {vfs}/tree/sub1/b {vfs}/tree/sub1/sub2/c"], "verify": ["match test $(find {vfs}/tree | wc -l) -eq 7"]},
    {"id": "181", "description": "Create 6 dirs with same prefix, verify count", "setup": ["for d in dir1 dir2 dir3 dir4 dir5 dir6; do mkdir {vfs}/$d; done"], "verify": ["count {vfs} == 6"]},
    {"id": "182", "description": "rm -R nested then verify gone", "setup": ["mkdir -p {vfs}/deep/A/B/C/D", "touch {vfs}/deep/A/B/C/D/leaf", "rm -R {vfs}/deep"], "verify": ["not exists {vfs}/deep"]},
    {"id": "183", "description": "Copy multiple distinct file types at once", "setup": ["cp {src_pdf_small} {src_zip} {src_dmg} {src_yaml} {src_json} {src_xlsx} {vfs}/"], "verify": ["count {vfs} == 6"]},
    {"id": "184", "description": "Bulk touch creates file if not exist, leaves existing", "setup": ["touch {vfs}/a {vfs}/b", "echo content > {vfs}/a", "touch {vfs}/a {vfs}/c"], "verify": ["match test \"$(cat {vfs}/a)\" = 'content'", "exists {vfs}/c"]},
    {"id": "185", "description": "Verify cwd behavior inside mounted FS", "setup": ["mkdir {vfs}/workdir", "cp {src_pdf_small} {vfs}/workdir/file"], "verify": ["exists {vfs}/workdir/file"]},
    {"id": "186", "description": "Bulk chmod to make multiple files readable", "setup": ["mkdir {vfs}/multi", "for i in $(seq 1 8); do touch {vfs}/multi/f$i; chmod 644 {vfs}/multi/f$i; done"], "verify": ["match test $(stat -f %p {vfs}/multi/f1 | tail -c 4) = '644'"]},
    {"id": "187", "description": "Find biggest file in tree", "setup": ["python3 -c 'import sys; f=open(sys.argv[1],\"wb\"); f.write(b\"\\0\"*100000); f.close()' {vfs}/small", "python3 -c 'import sys; f=open(sys.argv[1],\"wb\"); f.write(b\"\\0\"*1000000); f.close()' {vfs}/big"], "verify": ["match test \"$(find {vfs}/ -type f -size +500000c | head -1)\" = '{vfs}/big'"]},
    {"id": "188", "description": "Bulk move all *.pdf to a subdir", "setup": ["mkdir {vfs}/pdfs", "cp {src_pdf_small} {vfs}/a.pdf", "cp {src_pdf_large} {vfs}/b.pdf", "mv {vfs}/*.pdf {vfs}/pdfs/"], "verify": ["exists {vfs}/pdfs/a.pdf", "exists {vfs}/pdfs/b.pdf"]},
    {"id": "189", "description": "Du name shows path", "setup": ["mkdir -p {vfs}/deep/very/very/deep/path", "python3 -c 'import sys; open(sys.argv[1],\"wb\").write(b\"deep\")' {vfs}/deep/very/very/deep/path/file"], "verify": ["match test \"$(du -h {vfs}/deep/very/very/deep/path/file 2>/dev/null | awk '{print $1}')\" = '4B' || test -f {vfs}/deep/very/very/deep/path/file"]},
    {"id": "190", "description": "Bulk rename extension", "setup": ["mkdir {vfs}/renames", "for i in 1 2 3 4; do touch {vfs}/renames/f$i.txt; done", "for i in 1 2 3 4; do mv {vfs}/renames/f$i.txt {vfs}/renames/f$i.md; done"], "verify": ["match test $(ls {vfs}/renames/ | grep -c '\\.md$') -eq 4"]},
    {"id": "191", "description": "Create 3 sibling trees, all 3 levels", "setup": ["for t in alpha beta gamma; do mkdir -p {vfs}/$t/level1/level2; touch {vfs}/$t/level1/level2/file; done"], "verify": ["match test $(find {vfs}/ -name file | wc -l) -eq 3"]},
    {"id": "192", "description": "Verify recursive copy preserves directory names exactly", "setup": ["mkdir -p {vfs}/complex-name_with.dots-123/sub_dir", "touch {vfs}/complex-name_with.dots-123/sub_dir/x", "cp -R {vfs}/complex-name_with.dots-123 {vfs}/copy_dir/"], "verify": ["exists {vfs}/copy_dir/complex-name_with.dots-123/sub_dir/x"]},
    {"id": "193", "description": "Bulk cat all files in dir", "setup": ["mkdir {vfs}/catdir", "for i in $(seq 1 6); do echo \"line$i\" > {vfs}/catdir/f$i; done", "match test \"$(cat {vfs}/catdir/f1 {vfs}/catdir/f2 {vfs}/catdir/f3 | wc -l)\" -eq 3"], "verify": ["count {vfs}/catdir == 6"]},
    {"id": "194", "description": "rm -R when destination is non-empty", "setup": ["mkdir {vfs}/keep", "touch {vfs}/keep/x", "mkdir {vfs}/kill", "touch {vfs}/kill/y", "rm -R {vfs}/kill"], "verify": ["not exists {vfs}/kill", "exists {vfs}/keep"]},
    {"id": "195", "description": "Bulk copy with rename", "setup": ["for i in 1 2 3 4; do touch {vfs}/orig$i; done", "for i in 1 2 3 4; do cp {vfs}/orig$i {vfs}/copy$i; done"], "verify": ["count {vfs} == 8"]},
    {"id": "196", "description": "find and xargs-style bulk delete", "setup": ["mkdir {vfs}/delete_target", "for i in $(seq 1 12); do touch {vfs}/delete_target/t$i; done", "for i in $(seq 1 12); do rm {vfs}/delete_target/t$i; done"], "verify": ["count {vfs}/delete_target == 0"]},
    {"id": "197", "description": "Bulk create deep nested dirs", "setup": ["for d in 1 2 3 4 5; do mkdir -p {vfs}/tree$d/A/B; touch {vfs}/tree$d/A/B/f; done"], "verify": ["match test $(find {vfs}/ -name f | wc -l) -eq 5"]},
    {"id": "198", "description": "Copy file to 5 different locations", "setup": ["mkdir {vfs}/loc1 {vfs}/loc2 {vfs}/loc3 {vfs}/loc4 {vfs}/loc5", "for d in loc1 loc2 loc3 loc4 loc5; do cp {src_pdf_small} {vfs}/$d/copy; done"], "verify": ["match test $(md5 -q {vfs}/loc1/copy {vfs}/loc2/copy {vfs}/loc3/copy {vfs}/loc4/copy {vfs}/loc5/copy | sort -u | wc -l) -eq 1"]},
    {"id": "199", "description": "Bulk move with extension change", "setup": ["for i in 1 2 3 4 5; do touch {vfs}/$i.txt; done", "for i in 1 2 3 4 5; do mv {vfs}/$i.txt {vfs}/d$i/; done", "mkdir {vfs}/d1 {vfs}/d2 {vfs}/d3 {vfs}/d4 {vfs}/d5", "for i in 1 2 3 4 5; do mv {vfs}/$i.txt {vfs}/d$i/; done"], "verify": ["match test $(ls {vfs}/d1/ | wc -l) -eq 1"]},
    {"id": "200", "description": "Final bulk: create 24 dirs each with 1 file, count total", "setup": ["for d in $(seq -w 1 24); do mkdir {vfs}/d$d; touch {vfs}/d$d/x; done", "match test $(find {vfs}/ -type f | wc -l) -eq 24"], "verify": ["match test $(find {vfs}/ -type d -mindepth 1 | wc -l) -eq 24"]}
  ]
}