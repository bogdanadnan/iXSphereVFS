{
  "_doc": "Batch 6 — 50 distinct, edge case scenarios. Each is a unique transformation.",
  "scenarios": [
    {"id": "251", "description": "Create file with dot prefix (.hidden)", "setup": ["touch {vfs}/.hidden"], "verify": ["exists {vfs}/.hidden"]},
    {"id": "252", "description": "Create file with no extension", "setup": ["touch {vfs}/Makefile"], "verify": ["exists {vfs}/Makefile"]},
    {"id": "253", "description": "Create file with multiple dots in name", "setup": ["touch {vfs}/archive.tar.gz"], "verify": ["exists {vfs}/archive.tar.gz"]},
    {"id": "254", "description": "Create file with hyphen prefix", "setup": ["touch {vfs}/-dash-start"], "verify": ["exists {vfs}/-dash-start"]},
    {"id": "255", "description": "Create file with underscore name", "setup": ["touch {vfs}/under_score"], "verify": ["exists {vfs}/under_score"]},
    {"id": "256", "description": "Create file with numbers only in name", "setup": ["touch {vfs}/12345"], "verify": ["exists {vfs}/12345"]},
    {"id": "257", "description": "Create file with single char name", "setup": ["touch {vfs}/a"], "verify": ["exists {vfs}/a"]},
    {"id": "258", "description": "Create file with two-char name", "setup": ["touch {vfs}/ab"], "verify": ["exists {vfs}/ab"]},
    {"id": "259", "description": "Create file starting with dot but no extension", "setup": ["touch {vfs}/.gitignore"], "verify": ["exists {vfs}/.gitignore"]},
    {"id": "260", "description": "Create dir with dot in middle of name", "setup": ["mkdir {vfs}/my.dir"], "verify": ["isdir {vfs}/my.dir"]},
    {"id": "261", "description": "Create file with dollar sign", "setup": ["touch {vfs}/'price$100'"], "verify": ["exists {vfs}/price$100"]},
    {"id": "262", "description": "Create file with plus sign in name", "setup": ["touch {vfs}/c++"], "verify": ["exists {vfs}/c++"]},
    {"id": "263", "description": "Create file with at-sign", "setup": ["touch {vfs}/user@host"], "verify": ["exists {vfs}/user@host"]},
    {"id": "264", "description": "Create file with brackets", "setup": ["touch {vfs}/file[1]"], "verify": ["exists {vfs}/file[1]"]},
    {"id": "265", "description": "Create file with parentheses", "setup": ["touch {vfs}/file(1)"], "verify": ["exists {vfs}/file(1)"]},
    {"id": "266", "description": "Create file with caret", "setup": ["touch {vfs}/caret^x"], "verify": ["exists {vfs}/caret^x"]},
    {"id": "267", "description": "Create file with pipe", "setup": ["touch {vfs}/pipe|name"], "verify": ["exists {vfs}/pipe|name"]},
    {"id": "268", "description": "Create file with ampersand", "setup": ["touch {vfs}/and&name"], "verify": ["exists {vfs}/and&name"]},
    {"id": "269", "description": "Create file with semicolon", "setup": ["touch {vfs}/semi;name"], "verify": ["exists {vfs}/semi;name"]},
    {"id": "270", "description": "Create file with apostrophe", "setup": ["touch {vfs}/apos'test"], "verify": ["exists {vfs}/apos'test"]},
    {"id": "271", "description": "Create file with double quote", "setup": ["touch {vfs}/quote\\\"test"], "verify": ["exists {vfs}/quote\"test"]},
    {"id": "272", "description": "Create file with backslash", "setup": ["touch {vfs}/back\\\\slash"], "verify": ["exists {vfs}/back\\\\slash"]},
    {"id": "273", "description": "Create file with hash", "setup": ["touch {vfs}/hash#file"], "verify": ["exists {vfs}/hash#file"]},
    {"id": "274", "description": "Create file with percent", "setup": ["touch {vfs}/percent%"], "verify": ["exists {vfs}/percent%"]},
    {"id": "275", "description": "Create file with tilde", "setup": ["touch {vfs}/tilde~file"], "verify": ["exists {vfs}/tilde~file"]},
    {"id": "276", "description": "Create file with backtick", "setup": ["touch {vfs}/back\\`tick"], "verify": ["exists {vfs}/back`tick"]},
    {"id": "277", "description": "Create empty file and check size 0", "setup": ["touch {vfs}/empty"], "verify": ["size {vfs}/empty == 0"]},
    {"id": "278", "description": "Create dir then rename to same name (no-op)", "setup": ["mkdir {vfs}/d", "mv {vfs}/d {vfs}/d"], "verify": ["isdir {vfs}/d"]},
    {"id": "279", "description": "Create file, rename to itself", "setup": ["cp {src_pdf_small} {vfs}/f", "mv {vfs}/f {vfs}/f"], "verify": ["exists {vfs}/f"]},
    {"id": "280", "description": "Create deeply nested same-name dirs", "setup": ["mkdir -p {vfs}/a/a/a/a"], "verify": ["exists {vfs}/a/a/a/a"]},
    {"id": "281", "description": "Create file, rename parent, file's parent path changes", "setup": ["mkdir {vfs}/p1", "cp {src_pdf_small} {vfs}/p1/f", "mv {vfs}/p1 {vfs}/p2"], "verify": ["not exists {vfs}/p1/f", "exists {vfs}/p2/f", "md5 {vfs}/p2/f == src_pdf_small"]},
    {"id": "282", "description": "Create file with name matching dir name", "setup": ["mkdir {vfs}/foo", "touch {vfs}/foo"], "verify": ["isdir {vfs}/foo", "exists {vfs}/foo"]},
    {"id": "283", "description": "Create dir with name matching file name", "setup": ["touch {vfs}/bar", "mkdir {vfs}/bar"], "verify": ["exists {vfs}/bar", "isdir {vfs}/bar"]},
    {"id": "284", "description": "Create file with trailing dot", "setup": ["touch {vfs}/trailing."], "verify": ["exists {vfs}/trailing."]},
    {"id": "285", "description": "Create file with leading dot", "setup": ["touch {vfs}/.leading"], "verify": ["exists {vfs}/.leading"]},
    {"id": "286", "description": "Create two files that differ only by case", "setup": ["touch {vfs}/File {vfs}/file"], "verify": ["exists {vfs}/File", "exists {vfs}/file"]},
    {"id": "287", "description": "Create file then rename with case change", "setup": ["touch {vfs}/lower", "mv {vfs}/lower {vfs}/Lower"], "verify": ["exists {vfs}/Lower"]},
    {"id": "288", "description": "Create file, write single byte, MD5", "setup": ["printf X > {vfs}/x"], "verify": ["size {vfs}/x == 2"]},
    {"id": "289", "description": "Create file with 100-char name", "setup": ["python3 -c 'import os,sys; open(os.path.join(sys.argv[1], \"a\"*100), \"w\").close()' {vfs}"], "verify": ["exists {vfs}/$(python3 -c 'print(\"a\"*100)')"]},
    {"id": "290", "description": "Create file with 50-char name", "setup": ["python3 -c 'import os,sys; open(os.path.join(sys.argv[1], \"x\"*50), \"w\").close()' {vfs}"], "verify": ["exists {vfs}/$(python3 -c 'print(\"x\"*50)')"]},
    {"id": "291", "description": "Create file then write 0 bytes (truncate)", "setup": ["cp {src_pdf_small} {vfs}/t", "python3 -c 'import sys; open(sys.argv[1],\"wb\").close()' {vfs}/t"], "verify": ["size {vfs}/t == 0"]},
    {"id": "292", "description": "Create file, write 4096 bytes (page boundary)", "setup": ["python3 -c 'import sys; open(sys.argv[1],\"wb\").write(b\"\\0\"*4096)' {vfs}/page"], "verify": ["size {vfs}/page == 4096"]},
    {"id": "293", "description": "Create file with content 4097 bytes (1 past page)", "setup": ["python3 -c 'import sys; open(sys.argv[1],\"wb\").write(b\"\\0\"*4097)' {vfs}/p"], "verify": ["size {vfs}/p == 4097"]},
    {"id": "294", "description": "Create file, write 8191 bytes (1 less than 2 pages)", "setup": ["python3 -c 'import sys; open(sys.argv[1],\"wb\").write(b\"\\0\"*8191)' {vfs}/p"], "verify": ["size {vfs}/p == 8191"]},
    {"id": "295", "description": "Create file, write 8193 bytes (1 past 2 pages)", "setup": ["python3 -c 'import sys; open(sys.argv[1],\"wb\").write(b\"\\0\"*8193)' {vfs}/p"], "verify": ["size {vfs}/p == 8193"]},
    {"id": "296", "description": "Create file with maximum page-aligned size (16 pages)", "setup": ["python3 -c 'import sys; open(sys.argv[1],\"wb\").write(b\"\\0\"*131072)' {vfs}/p16"], "verify": ["size {vfs}/p16 == 131072"]},
    {"id": "297", "description": "Create empty dir, ls shows empty", "setup": ["mkdir {vfs}/empty_dir"], "verify": ["match test $(ls -1 {vfs}/empty_dir | wc -l) -eq 0"]},
    {"id": "298", "description": "Create dir with name 'a', contains 1 file", "setup": ["mkdir {vfs}/a", "touch {vfs}/a/single"], "verify": ["count {vfs}/a == 1"]},
    {"id": "299", "description": "Create file with name starting with number", "setup": ["touch {vfs}/1file"], "verify": ["exists {vfs}/1file"]},
    {"id": "300", "description": "Create files with names containing only digits", "setup": ["for i in $(seq 1 8); do touch {vfs}/$i; done"], "verify": ["match test $(ls {vfs}/ | grep -E '^[0-9]+$' | wc -l) -eq 8"]}
  ]
}