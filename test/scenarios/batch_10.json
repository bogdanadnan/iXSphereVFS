{
  "_doc": "Batch 10 — 50 distinct, misc scenarios. Each is a unique transformation.",
  "scenarios": [
    {"id": "451", "description": "Create file, chmod 600, verify mode", "setup": ["touch {vfs}/restricted", "chmod 600 {vfs}/restricted"], "verify": ["mode {vfs}/restricted == 0600"]},
    {"id": "452", "description": "Create file, chmod 755, verify mode", "setup": ["cp {src_pdf_small} {vfs}/executable", "chmod 755 {vfs}/executable"], "verify": ["mode {vfs}/executable == 0755"]},
    {"id": "453", "description": "Create file, chmod 644, verify mode", "setup": ["cp {src_pdf_small} {vfs}/normal", "chmod 644 {vfs}/normal"], "verify": ["mode {vfs}/normal == 0644"]},
    {"id": "454", "description": "Create file, chmod 400, verify mode", "setup": ["cp {src_pdf_small} {vfs}/readonly", "chmod 400 {vfs}/readonly"], "verify": ["mode {vfs}/readonly == 0400"]},
    {"id": "455", "description": "Create dir, chmod 700, verify", "setup": ["mkdir {vfs}/priv_dir", "chmod 700 {vfs}/priv_dir"], "verify": ["isdir {vfs}/priv_dir"]},
    {"id": "456", "description": "Create dir, chmod 755, verify", "setup": ["mkdir {vfs}/pub_dir", "chmod 755 {vfs}/pub_dir"], "verify": ["isdir {vfs}/pub_dir"]},
    {"id": "457", "description": "Create file, chmod 0, file still exists", "setup": ["cp {src_pdf_small} {vfs}/noperm", "chmod 0 {vfs}/noperm"], "verify": ["exists {vfs}/noperm"]},
    {"id": "458", "description": "Create file, chmod 777, verify", "setup": ["touch {vfs}/allperm", "chmod 777 {vfs}/allperm"], "verify": ["mode {vfs}/allperm == 0777"]},
    {"id": "459", "description": "Create file, chmod 111, verify", "setup": ["touch {vfs}/exec_only", "chmod 111 {vfs}/exec_only"], "verify": ["mode {vfs}/exec_only == 0111"]},
    {"id": "460", "description": "Create file, chmod 222, verify", "setup": ["touch {vfs}/write_only", "chmod 222 {vfs}/write_only"], "verify": ["mode {vfs}/write_only == 0222"]},
    {"id": "461", "description": "Create empty file with extension .log", "setup": ["touch {vfs}/app.log"], "verify": ["exists {vfs}/app.log", "size {vfs}/app.log == 0"]},
    {"id": "462", "description": "Create file .DS_Store (macOS metadata file)", "setup": ["touch {vfs}/.DS_Store"], "verify": ["exists {vfs}/.DS_Store"]},
    {"id": "463", "description": "Create file with .swp extension (vim swap)", "setup": ["touch {vfs}/file.swp"], "verify": ["exists {vfs}/file.swp"]},
    {"id": "464", "description": "Create file with .bak extension (backup)", "setup": ["touch {vfs}/data.bak"], "verify": ["exists {vfs}/data.bak"]},
    {"id": "465", "description": "Create file with .tmp extension", "setup": ["touch {vfs}/scratch.tmp"], "verify": ["exists {vfs}/scratch.tmp"]},
    {"id": "466", "description": "Create file with .lock extension", "setup": ["touch {vfs}/mutex.lock"], "verify": ["exists {vfs}/mutex.lock"]},
    {"id": "467", "description": "Create file with .pid extension", "setup": ["echo 12345 > {vfs}/process.pid"], "verify": ["match test \"$(cat {vfs}/process.pid)\" = '12345'"]},
    {"id": "468", "description": "Create file with .json extension", "setup": ["echo '{}' > {vfs}/config.json"], "verify": ["match test \"$(cat {vfs}/config.json)\" = '{}'"]},
    {"id": "469", "description": "Create file with .xml extension", "setup": ["echo '<root/>' > {vfs}/data.xml"], "verify": ["match test \"$(cat {vfs}/data.xml)\" = '<root/>'"]},
    {"id": "470", "description": "Create file with .html extension", "setup": ["echo '<html></html>' > {vfs}/page.html"], "verify": ["match test \"$(cat {vfs}/page.html)\" = '<html></html>'"]},
    {"id": "471", "description": "Create dir with .config extension", "setup": ["mkdir {vfs}/app.config"], "verify": ["isdir {vfs}/app.config"]},
    {"id": "472", "description": "Create file with .exe extension", "setup": ["python3 -c 'import sys; open(sys.argv[1],\"wb\").write(b\"MZ\")' {vfs}/app.exe"], "verify": ["size {vfs}/app.exe == 2"]},
    {"id": "473", "description": "Create file with version number in name", "setup": ["touch {vfs}/lib-1.2.3.so"], "verify": ["exists {vfs}/lib-1.2.3.so"]},
    {"id": "474", "description": "Create file with hash-like name", "setup": ["touch {vfs}/a1b2c3d4e5f6"], "verify": ["exists {vfs}/a1b2c3d4e5f6"]},
    {"id": "475", "description": "Create file with date-like name", "setup": ["touch {vfs}/2026-07-09.txt"], "verify": ["exists {vfs}/2026-07-09.txt"]},
    {"id": "476", "description": "Create dir with date-like name", "setup": ["mkdir {vfs}/2026-07-10"], "verify": ["isdir {vfs}/2026-07-10"]},
    {"id": "477", "description": "Create file, write CRLF line endings", "setup": ["printf 'line1\\r\\nline2\\r\\n' > {vfs}/crlf.txt"], "verify": ["match test \"$(cat {vfs}/crlf.txt | wc -l)\" -eq 2"]},
    {"id": "478", "description": "Create file with only whitespace content", "setup": ["printf '   \\n' > {vfs}/ws.txt"], "verify": ["size {vfs}/ws.txt == 4"]},
    {"id": "479", "description": "Create file with single newline", "setup": ["printf '\\n' > {vfs}/n.txt"], "verify": ["size {vfs}/n.txt == 1"]},
    {"id": "480", "description": "Create file with NUL byte content", "setup": ["printf '\\x00' > {vfs}/null.txt"], "verify": ["size {vfs}/null.txt == 1"]},
    {"id": "481", "description": "Create file with single null + text", "setup": ["printf '\\x00hello' > {vfs}/nullhello.txt"], "verify": ["size {vfs}/nullhello.txt == 6"]},
    {"id": "482", "description": "Create file with trailing whitespace", "setup": ["printf 'data   ' > {vfs}/trail.txt"], "verify": ["size {vfs}/trail.txt == 7"]},
    {"id": "483", "description": "Create file with no trailing newline", "setup": ["printf 'no_newline' > {vfs}/nn.txt"], "verify": ["match test \"$(wc -c < {vfs}/nn.txt)\" -eq 11"]},
    {"id": "484", "description": "Create file with multiple consecutive newlines", "setup": ["printf 'a\\n\\n\\nb\\n\\nc' > {vfs}/multi_nl.txt"], "verify": ["size {vfs}/multi_nl.txt == 7"]},
    {"id": "485", "description": "Create file with tab characters", "setup": ["printf 'col1\\tcol2\\tcol3' > {vfs}/tab.txt"], "verify": ["size {vfs}/tab.txt == 14"]},
    {"id": "486", "description": "Create file with mix of spaces and tabs", "setup": ["printf 'a\\tb c\\td' > {vfs}/mixed_ws.txt"], "verify": ["exists {vfs}/mixed_ws.txt"]},
    {"id": "487", "description": "Create file with ANSI escape sequences", "setup": ["printf '\\033[31mred\\033[0m' > {vfs}/ansi.txt"], "verify": ["size {vfs}/ansi.txt == 11"]},
    {"id": "488", "description": "Create file with binary pattern", "setup": ["python3 -c 'import sys; open(sys.argv[1],\"wb\").write(bytes([0xDE,0xAD,0xBE,0xEF]*4))' {vfs}/magic"], "verify": ["size {vfs}/magic == 16"]},
    {"id": "489", "description": "Create file with text + binary", "setup": ["python3 -c 'import sys; open(sys.argv[1],\"wb\").write(b\"header\\x00\\x01\\x02binary\")' {vfs}/mixed"], "verify": ["size {vfs}/mixed == 16"]},
    {"id": "490", "description": "Create file with leading BOM", "setup": ["python3 -c 'import sys; open(sys.argv[1],\"wb\").write(b\"\\xef\\xbb\\xbfhello\")' {vfs}/bom.txt"], "verify": ["size {vfs}/bom.txt == 8"]},
    {"id": "491", "description": "Create file with null-padded content", "setup": ["python3 -c 'import sys; open(sys.argv[1],\"wb\").write(b\"data\"+b\"\\0\"*100)' {vfs}/padded"], "verify": ["size {vfs}/padded == 104"]},
    {"id": "492", "description": "Create file, then read 0 bytes from offset 0", "setup": ["cp {src_pdf_small} {vfs}/r", "python3 -c 'import sys; f=open(sys.argv[1],\"rb\"); print(len(f.read(0)))' {vfs}/r"], "verify": ["exists {vfs}/r"]},
    {"id": "493", "description": "Create file, then read past EOF", "setup": ["cp {src_pdf_small} {vfs}/r2", "python3 -c 'import sys; f=open(sys.argv[1],\"rb\"); f.seek(0,2); print(len(f.read(1000)))' {vfs}/r2"], "verify": ["exists {vfs}/r2"]},
    {"id": "494", "description": "Create 2 dirs with similar prefix, verify count", "setup": ["mkdir {vfs}/prefix {vfs}/prefixed"], "verify": ["count {vfs} == 2"]},
    {"id": "495", "description": "Create 3 files with same name differing in dir", "setup": ["mkdir {vfs}/d1 {vfs}/d2 {vfs}/d3", "echo 1 > {vfs}/d1/file", "echo 2 > {vfs}/d2/file", "echo 3 > {vfs}/d3/file"], "verify": ["match test \"$(cat {vfs}/d1/file)$(cat {vfs}/d2/file)$(cat {vfs}/d3/file)\" = '123'"]},
    {"id": "496", "description": "Create file, then rename repeatedly with same name (idempotent)", "setup": ["touch {vfs}/x", "mv {vfs}/x {vfs}/y", "mv {vfs}/y {vfs}/z", "mv {vfs}/z {vfs}/z"], "verify": ["exists {vfs}/z"]},
    {"id": "497", "description": "Create file then write in increments of 1KB", "setup": ["python3 -c 'import sys; f=open(sys.argv[1],\"wb\"); [f.write(b\"X\"*1024) for _ in range(8)]; f.close()' {vfs}/inc"], "verify": ["size {vfs}/inc == 8192"]},
    {"id": "498", "description": "Create file then verify stat mode 0644 after chmod", "setup": ["touch {vfs}/mode_test", "chmod 644 {vfs}/mode_test"], "verify": ["match test $(stat -f %p {vfs}/mode_test | tail -c 4) = '644'"]},
    {"id": "499", "description": "Create file then re-mount flow check: write, read same", "setup": ["cp {src_pdf_small} {vfs}/check", "python3 -c 'import sys; print(open(sys.argv[1],\"rb\").read()[:10])' {vfs}/check"], "verify": ["md5 {vfs}/check == src_pdf_small"]},
    {"id": "500", "description": "Final: create comprehensive test environment", "setup": ["mkdir -p {vfs}/final/sub1/sub2", "cp {src_pdf_small} {vfs}/final/a", "cp {src_pdf_large} {vfs}/final/b", "cp {src_zip} {vfs}/final/c", "touch {vfs}/final/sub1/file", "echo test > {vfs}/final/sub1/sub2/inner"], "verify": ["md5 {vfs}/final/a == src_pdf_small", "md5 {vfs}/final/b == src_pdf_large", "md5 {vfs}/final/c == src_zip", "match test \"$(cat {vfs}/final/sub1/sub2/inner)\" = 'test'"]}
  ]
}