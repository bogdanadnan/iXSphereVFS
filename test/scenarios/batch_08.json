{
  "_doc": "Batch 8 — 50 distinct, recovery scenarios. Each is a unique transformation. Tests persistence and mount remount behavior.",
  "scenarios": [
    {"id": "351", "description": "Write file, unmount, remount, file still there", "setup": ["cp {src_pdf_small} {vfs}/persistent"], "verify": ["md5 {vfs}/persistent == src_pdf_small"]},
    {"id": "352", "description": "Create 5 files, expect all to persist", "setup": ["for i in 1 2 3 4 5; do touch {vfs}/p$i; done"], "verify": ["count {vfs} == 5"]},
    {"id": "353", "description": "Create deeply nested dirs, persist across mount cycle", "setup": ["mkdir -p {vfs}/d1/d2/d3/d4"], "verify": ["exists {vfs}/d1/d2/d3/d4"]},
    {"id": "354", "description": "Write 1MB, persist", "setup": ["python3 -c 'import sys; open(sys.argv[1],\"wb\").write(b\"\\0\"*1048576)' {vfs}/mb"], "verify": ["size {vfs}/mb == 1048576"]},
    {"id": "355", "description": "Create file with long name, persist", "setup": ["python3 -c 'import os,sys; open(os.path.join(sys.argv[1], \"L\"*100), \"w\").close()' {vfs}"], "verify": ["exists {vfs}/$(python3 -c 'print(\"L\"*100)')"]},
    {"id": "356", "description": "Create dir with file inside, both persist", "setup": ["mkdir {vfs}/sub", "cp {src_pdf_small} {vfs}/sub/f"], "verify": ["md5 {vfs}/sub/f == src_pdf_small"]},
    {"id": "357", "description": "Bulk create, then list, all persist", "setup": ["for i in $(seq 1 12); do touch {vfs}/bulk$i; done"], "verify": ["count {vfs} == 12"]},
    {"id": "358", "description": "Create file, write content, persist", "setup": ["echo persisted_content > {vfs}/content_file"], "verify": ["match test \"$(cat {vfs}/content_file)\" = 'persisted_content'"]},
    {"id": "359", "description": "Append then persist", "setup": ["echo part1 > {vfs}/two_part", "echo part2 >> {vfs}/two_part"], "verify": ["match test \"$(cat {vfs}/two_part | tr -d '\\n')\" = 'part1part2'"]},
    {"id": "360", "description": "Truncate then persist", "setup": ["cp {src_pdf_small} {vfs}/trunc", "python3 -c 'import sys; open(sys.argv[1],\"r+b\").truncate(50)' {vfs}/trunc"], "verify": ["size {vfs}/trunc == 50"]},
    {"id": "361", "description": "Create file then rename then verify both", "setup": ["touch {vfs}/before_rename", "mv {vfs}/before_rename {vfs}/after_rename"], "verify": ["not exists {vfs}/before_rename", "exists {vfs}/after_rename"]},
    {"id": "362", "description": "Create dir with 8 children, persist", "setup": ["mkdir {vfs}/eight_kids", "for i in $(seq 1 8); do touch {vfs}/eight_kids/k$i; done"], "verify": ["count {vfs}/eight_kids == 8"]},
    {"id": "363", "description": "Create copy of large file, persist", "setup": ["cp {src_zip} {vfs}/copy_zip"], "verify": ["md5 {vfs}/copy_zip == src_zip"]},
    {"id": "364", "description": "Create file with 0 bytes, persist", "setup": ["touch {vfs}/empty_p"], "verify": ["size {vfs}/empty_p == 0"]},
    {"id": "365", "description": "Create 3 nested dirs at root, persist", "setup": ["mkdir -p {vfs}/r/a/b"], "verify": ["exists {vfs}/r/a/b"]},
    {"id": "366", "description": "Create file then truncate to 0 then persist", "setup": ["cp {src_pdf_small} {vfs}/z", "python3 -c 'import sys; open(sys.argv[1],\"wb\").close()' {vfs}/z"], "verify": ["size {vfs}/z == 0"]},
    {"id": "367", "description": "Create 2 dirs with files, persist all", "setup": ["mkdir {vfs}/dA {vfs}/dB", "echo A > {vfs}/dA/x", "echo B > {vfs}/dB/y"], "verify": ["match test \"$(cat {vfs}/dA/x)\" = 'A'", "match test \"$(cat {vfs}/dB/y)\" = 'B'"]},
    {"id": "368", "description": "Create file with binary content, persist", "setup": ["python3 -c 'import sys; open(sys.argv[1],\"wb\").write(bytes(range(256)))' {vfs}/binary"], "verify": ["size {vfs}/binary == 256"]},
    {"id": "369", "description": "Create 10 files in nested dir, persist", "setup": ["mkdir -p {vfs}/nest", "for i in $(seq 1 10); do touch {vfs}/nest/n$i; done"], "verify": ["count {vfs}/nest == 10"]},
    {"id": "370", "description": "Create and delete file, file stays gone", "setup": ["touch {vfs}/temp", "rm {vfs}/temp"], "verify": ["not exists {vfs}/temp"]},
    {"id": "371", "description": "Create file with mode 644, persist", "setup": ["touch {vfs}/modelf", "chmod 644 {vfs}/modelf"], "verify": ["mode {vfs}/modelf == 0644"]},
    {"id": "372", "description": "Create file with spaces, persist", "setup": ["touch {vfs}/file\\ with\\ spaces"], "verify": ["exists {vfs}/file with spaces"]},
    {"id": "373", "description": "Create unicode-named file, persist", "setup": ["touch {vfs}/тест"], "verify": ["exists {vfs}/тест"]},
    {"id": "374", "description": "Create dir with multiple files (write+read), persist", "setup": ["mkdir {vfs}/write_read", "python3 -c 'import sys; open(sys.argv[1]+\"/f1\",\"wb\").write(b\"AAA\"); open(sys.argv[1]+\"/f2\",\"wb\").write(b\"BBB\")' {vfs}"], "verify": ["match test \"$(python3 -c 'print(open(sys.argv[1]+\"/f1\",\"rb\").read().decode())' {vfs})\" = 'AAA'"]},
    {"id": "375", "description": "Create file via python write, persist", "setup": ["python3 -c 'import sys; open(sys.argv[1],\"wb\").write(b\"via python\")' {vfs}/py_write"], "verify": ["match test \"$(cat {vfs}/py_write)\" = 'via python'"]},
    {"id": "376", "description": "Create 4 dirs with similar names", "setup": ["mkdir {vfs}/d1 {vfs}/d1a {vfs}/d1b {vfs}/d1ab"], "verify": ["count {vfs} == 4"]},
    {"id": "377", "description": "Create dir with 6 children including a subdir", "setup": ["mkdir {vfs}/parent_p", "touch {vfs}/parent_p/c1 {vfs}/parent_p/c2 {vfs}/parent_p/c3", "mkdir {vfs}/parent_p/sub_p", "touch {vfs}/parent_p/sub_p/inner"], "verify": ["count {vfs}/parent_p == 4"]},
    {"id": "378", "description": "Create file, then duplicate as same content", "setup": ["cp {src_pdf_small} {vfs}/orig_p", "cp {vfs}/orig_p {vfs}/copy_p"], "verify": ["md5 {vfs}/copy_p == src_pdf_small"]},
    {"id": "379", "description": "Create file then write at offset, persist", "setup": ["python3 -c 'import sys; f=open(sys.argv[1],\"wb\"); f.write(b\"\\0\"*100); f.seek(50); f.write(b\"X\"); f.close()' {vfs}/punch_p"], "verify": ["size {vfs}/punch_p == 100"]},
    {"id": "380", "description": "Create then rename dir, contents persist", "setup": ["mkdir {vfs}/old_p", "cp {src_pdf_small} {vfs}/old_p/file", "mv {vfs}/old_p {vfs}/new_p"], "verify": ["exists {vfs}/new_p/file", "md5 {vfs}/new_p/file == src_pdf_small"]},
    {"id": "381", "description": "Create 8 dirs in flat structure", "setup": ["for d in a1 a2 a3 a4 a5 a6 a7 a8; do mkdir {vfs}/$d; done"], "verify": ["count {vfs} == 8"]},
    {"id": "382", "description": "Create file and copy to subdir, persist", "setup": ["mkdir {vfs}/dst_sub", "cp {src_pdf_small} {vfs}/dst_sub/c"], "verify": ["md5 {vfs}/dst_sub/c == src_pdf_small"]},
    {"id": "383", "description": "Create 3 files then delete 1, persist state", "setup": ["touch {vfs}/keep_a {vfs}/keep_b {vfs}/delete_me", "rm {vfs}/delete_me"], "verify": ["count {vfs} == 2"]},
    {"id": "384", "description": "Create file with hash-like name, persist", "setup": ["touch {vfs}/abc123def456"], "verify": ["exists {vfs}/abc123def456"]},
    {"id": "385", "description": "Create file with .config extension, persist", "setup": ["echo data > {vfs}/app.config"], "verify": ["exists {vfs}/app.config"]},
    {"id": "386", "description": "Create file with no name extension", "setup": ["touch {vfs}/noext"], "verify": ["exists {vfs}/noext"]},
    {"id": "387", "description": "Create empty file via python, persist", "setup": ["python3 -c 'import sys; open(sys.argv[1],\"wb\").close()' {vfs}/pyempty"], "verify": ["size {vfs}/pyempty == 0"]},
    {"id": "388", "description": "Create file then mv to different dir, persist", "setup": ["mkdir {vfs}/dest_p", "touch {vfs}/movable", "mv {vfs}/movable {vfs}/dest_p/moved"], "verify": ["not exists {vfs}/movable", "exists {vfs}/dest_p/moved"]},
    {"id": "389", "description": "Create file, write 4KB, persist", "setup": ["python3 -c 'import sys; open(sys.argv[1],\"wb\").write(b\"\\0\"*4096)' {vfs}/4k"], "verify": ["size {vfs}/4k == 4096"]},
    {"id": "390", "description": "Create deeply nested file, persist", "setup": ["mkdir -p {vfs}/a/b/c/d/e", "echo bottom > {vfs}/a/b/c/d/e/file"], "verify": ["match test \"$(cat {vfs}/a/b/c/d/e/file)\" = 'bottom'"]},
    {"id": "391", "description": "Create directory with permission, persist", "setup": ["mkdir {vfs}/dir_perm", "chmod 755 {vfs}/dir_perm"], "verify": ["isdir {vfs}/dir_perm"]},
    {"id": "392", "description": "Create files at multiple depths, persist", "setup": ["mkdir -p {vfs}/L1/L2/L3", "touch {vfs}/L1/a {vfs}/L1/L2/b {vfs}/L1/L2/L3/c"], "verify": ["match test $(find {vfs}/L1 -type f | wc -l) -eq 3"]},
    {"id": "393", "description": "Create file then read 100 bytes, persist", "setup": ["python3 -c 'import sys; open(sys.argv[1],\"wb\").write(b\"X\"*1000)' {vfs}/r100", "python3 -c 'import sys; f=open(sys.argv[1],\"rb\"); print(f.read(100))' {vfs}/r100"], "verify": ["size {vfs}/r100 == 1000"]},
    {"id": "394", "description": "Create file with mixed text and binary", "setup": ["printf 'header\\x00\\x01\\x02\\x03\\nbody' > {vfs}/mixed"], "verify": ["exists {vfs}/mixed"]},
    {"id": "395", "description": "Create file, then duplicate name check", "setup": ["touch {vfs}/dupcheck", "ls {vfs}/dupcheck"], "verify": ["exists {vfs}/dupcheck"]},
    {"id": "396", "description": "Create 4 nested empty dirs", "setup": ["mkdir -p {vfs}/L0/L1/L2/L3"], "verify": ["exists {vfs}/L0/L1/L2/L3"]},
    {"id": "397", "description": "Create 2 files with different content", "setup": ["echo A > {vfs}/contentA", "echo B > {vfs}/contentB"], "verify": ["match test \"$(cat {vfs}/contentA)$(cat {vfs}/contentB)\" = 'AB'"]},
    {"id": "398", "description": "Create file with 4MB size, persist", "setup": ["python3 -c 'import sys; open(sys.argv[1],\"wb\").write(b\"\\0\"*4194304)' {vfs}/4mb"], "verify": ["size {vfs}/4mb == 4194304"]},
    {"id": "399", "description": "Create file with name + numeric suffix", "setup": ["touch {vfs}/log_001.txt"], "verify": ["exists {vfs}/log_001.txt"]},
    {"id": "400", "description": "Create file then mv to new name in same dir", "setup": ["touch {vfs}/origname", "mv {vfs}/origname {vfs}/newname"], "verify": ["not exists {vfs}/origname", "exists {vfs}/newname"]}
  ]
}