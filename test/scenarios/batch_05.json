{
  "_doc": "Batch 5 — 50 distinct, snapshot/epoch scenarios. Each is a unique transformation.",
  "scenarios": [
    {"id": "201", "description": "Write file, snapshot via .vfsctl, file persists", "setup": ["cp {src_pdf_small} {vfs}/file", "match printf snapshot > {vfs}/.vfsctl || true"], "verify": ["exists {vfs}/file"]},
    {"id": "202", "description": "Snapshot, write new file, both exist", "setup": ["cp {src_pdf_small} {vfs}/before", "match printf snapshot > {vfs}/.vfsctl || true", "cp {src_pdf_large} {vfs}/after"], "verify": ["exists {vfs}/before", "exists {vfs}/after"]},
    {"id": "203", "description": "Write then snapshot then read back", "setup": ["echo data > {vfs}/snap", "match printf snapshot > {vfs}/.vfsctl || true"], "verify": ["match test \"$(cat {vfs}/snap)\" = 'data'"]},
    {"id": "204", "description": "Snapshot then delete then re-create same name", "setup": ["cp {src_pdf_small} {vfs}/file", "match printf snapshot > {vfs}/.vfsctl || true", "rm {vfs}/file", "cp {src_pdf_large} {vfs}/file"], "verify": ["md5 {vfs}/file == src_pdf_large"]},
    {"id": "205", "description": "Multiple snapshots in succession", "setup": ["cp {src_pdf_small} {vfs}/v1", "match printf snapshot > {vfs}/.vfsctl || true", "cp {src_pdf_large} {vfs}/v2", "match printf snapshot > {vfs}/.vfsctl || true"], "verify": ["exists {vfs}/v1", "exists {vfs}/v2"]},
    {"id": "206", "description": "Snapshot then append, file size changes", "setup": ["cp {src_pdf_small} {vfs}/app", "match printf snapshot > {vfs}/.vfsctl || true", "printf x >> {vfs}/app"], "verify": ["size {vfs}/app == src_pdf_small_size + 1"]},
    {"id": "207", "description": "Create 3 files, snapshot, verify all exist", "setup": ["cp {src_pdf_small} {vfs}/a", "cp {src_pdf_large} {vfs}/b", "cp {src_zip} {vfs}/c", "match printf snapshot > {vfs}/.vfsctl || true"], "verify": ["count {vfs} == 3"]},
    {"id": "208", "description": "Snapshot then mkdir", "setup": ["match printf snapshot > {vfs}/.vfsctl || true", "mkdir {vfs}/newdir"], "verify": ["isdir {vfs}/newdir"]},
    {"id": "209", "description": "Snapshot then rename", "setup": ["cp {src_pdf_small} {vfs}/orig", "match printf snapshot > {vfs}/.vfsctl || true", "mv {vfs}/orig {vfs}/renamed"], "verify": ["not exists {vfs}/orig", "exists {vfs}/renamed"]},
    {"id": "210", "description": "Snapshot then overwrite file", "setup": ["cp {src_pdf_small} {vfs}/file", "match printf snapshot > {vfs}/.vfsctl || true", "cp {src_pdf_large} {vfs}/file"], "verify": ["size {vfs}/file == src_pdf_large_size"]},
    {"id": "211", "description": "Snapshot at empty state, then add content", "setup": ["match printf snapshot > {vfs}/.vfsctl || true", "cp {src_pdf_small} {vfs}/x"], "verify": ["exists {vfs}/x"]},
    {"id": "212", "description": "Create nested dir, snapshot, create deeper", "setup": ["mkdir {vfs}/a", "match printf snapshot > {vfs}/.vfsctl || true", "mkdir {vfs}/a/b"], "verify": ["exists {vfs}/a/b"]},
    {"id": "213", "description": "Snapshot after multiple writes", "setup": ["echo 1 > {vfs}/f1", "echo 2 > {vfs}/f2", "echo 3 > {vfs}/f3", "match printf snapshot > {vfs}/.vfsctl || true", "echo 4 > {vfs}/f4"], "verify": ["exists {vfs}/f1", "exists {vfs}/f2", "exists {vfs}/f3", "exists {vfs}/f4"]},
    {"id": "214", "description": "Snapshot then chmod", "setup": ["cp {src_pdf_small} {vfs}/p", "match printf snapshot > {vfs}/.vfsctl || true", "chmod 600 {vfs}/p"], "verify": ["exists {vfs}/p"]},
    {"id": "215", "description": "Snapshot then truncate", "setup": ["cp {src_pdf_small} {vfs}/t", "match printf snapshot > {vfs}/.vfsctl || true", "python3 -c 'import sys; open(sys.argv[1],\"r+b\").truncate(100)' {vfs}/t"], "verify": ["size {vfs}/t == 100"]},
    {"id": "216", "description": "Snapshot then rmdir of empty dir", "setup": ["mkdir {vfs}/empty", "match printf snapshot > {vfs}/.vfsctl || true", "rmdir {vfs}/empty"], "verify": ["not exists {vfs}/empty"]},
    {"id": "217", "description": "Snapshot then create file in nested dir", "setup": ["mkdir -p {vfs}/parent/child", "match printf snapshot > {vfs}/.vfsctl || true", "cp {src_pdf_small} {vfs}/parent/child/file"], "verify": ["md5 {vfs}/parent/child/file == src_pdf_small"]},
    {"id": "218", "description": "Snapshot before bulk copy", "setup": ["match printf snapshot > {vfs}/.vfsctl || true", "cp {src_pdf_small} {src_pdf_large} {src_zip} {src_dmg} {vfs}/"], "verify": ["count {vfs} == 4"]},
    {"id": "219", "description": "Snapshot then write 1MB file", "setup": ["match printf snapshot > {vfs}/.vfsctl || true", "python3 -c 'import sys; open(sys.argv[1],\"wb\").write(b\"\\0\"*1048576)' {vfs}/big"], "verify": ["size {vfs}/big == 1048576"]},
    {"id": "220", "description": "Snapshot then delete all files", "setup": ["for i in $(seq 1 8); do touch {vfs}/f$i; done", "match printf snapshot > {vfs}/.vfsctl || true", "rm {vfs}/f*"], "verify": ["count {vfs} == 0"]},
    {"id": "221", "description": "Create dir, snapshot, populate, verify", "setup": ["mkdir {vfs}/base", "match printf snapshot > {vfs}/.vfsctl || true", "for i in $(seq 1 8); do touch {vfs}/base/x$i; done"], "verify": ["count {vfs}/base == 8"]},
    {"id": "222", "description": "Snapshot then create deeply nested path", "setup": ["match printf snapshot > {vfs}/.vfsctl || true", "python3 -c 'import os; p=sys.argv[1]; os.makedirs(os.path.join(p, *[\"d\"+str(i) for i in range(5)]), exist_ok=True)' {vfs}"], "verify": ["exists {vfs}/d0/d1/d2/d3/d4"]},
    {"id": "223", "description": "Snapshot file content, snapshot again after modification", "setup": ["echo v1 > {vfs}/v", "match printf snapshot > {vfs}/.vfsctl || true", "echo v2 > {vfs}/v", "match printf snapshot > {vfs}/.vfsctl || true"], "verify": ["match test \"$(cat {vfs}/v)\" = 'v2'"]},
    {"id": "224", "description": "Snapshot then rename dir with content", "setup": ["mkdir {vfs}/sub", "touch {vfs}/sub/file", "match printf snapshot > {vfs}/.vfsctl || true", "mv {vfs}/sub {vfs}/renamed"], "verify": ["exists {vfs}/renamed/file"]},
    {"id": "225", "description": "Snapshot before destructive op, file unchanged at snapshot time", "setup": ["cp {src_pdf_small} {vfs}/safe", "match printf snapshot > {vfs}/.vfsctl || true", "rm {vfs}/safe"], "verify": ["not exists {vfs}/safe"]},
    {"id": "226", "description": "Snapshot at root with no files (empty state)", "setup": ["match printf snapshot > {vfs}/.vfsctl || true"], "verify": ["match ls {vfs}/ | wc -l"]},
    {"id": "227", "description": "Create file at epoch 0 (default), verify", "setup": ["cp {src_pdf_small} {vfs}/e0"], "verify": ["exists {vfs}/e0"]},
    {"id": "228", "description": "Create then snapshot then create then snapshot (multi-epoch)", "setup": ["echo a > {vfs}/a", "match printf snapshot > {vfs}/.vfsctl || true", "echo b > {vfs}/b", "match printf snapshot > {vfs}/.vfsctl || true", "echo c > {vfs}/c"], "verify": ["exists {vfs}/a", "exists {vfs}/b", "exists {vfs}/c"]},
    {"id": "229", "description": "Snapshot then bulk operations across many files", "setup": ["match printf snapshot > {vfs}/.vfsctl || true", "for i in $(seq 1 16); do touch {vfs}/snap_$i; done"], "verify": ["count {vfs} == 16"]},
    {"id": "230", "description": "Snapshot then deep copy tree", "setup": ["match printf snapshot > {vfs}/.vfsctl || true", "mkdir -p {vfs}/t/A/B", "touch {vfs}/t/A/file1 {vfs}/t/A/B/file2", "cp -R {vfs}/t {vfs}/t_copy/"], "verify": ["exists {vfs}/t_copy/t/A/B/file2"]},
    {"id": "231", "description": "Create then snapshot then read content preserved", "setup": ["python3 -c 'import sys; open(sys.argv[1],\"wb\").write(b\"PRESERVED\")' {vfs}/p", "match printf snapshot > {vfs}/.vfsctl || true"], "verify": ["match test \"$(cat {vfs}/p)\" = 'PRESERVED'"]},
    {"id": "232", "description": "Snapshot then file count preserved", "setup": ["for i in $(seq 1 12); do touch {vfs}/keep$i; done", "match printf snapshot > {vfs}/.vfsctl || true"], "verify": ["count {vfs} == 12"]},
    {"id": "233", "description": "Snapshot then write huge content", "setup": ["match printf snapshot > {vfs}/.vfsctl || true", "python3 -c 'import sys; open(sys.argv[1],\"wb\").write(b\"x\"*5000000)' {vfs}/big"], "verify": ["size {vfs}/big == 5000000"]},
    {"id": "234", "description": "Create with mkdir, snapshot, then create more subdirs", "setup": ["mkdir {vfs}/dir1", "match printf snapshot > {vfs}/.vfsctl || true", "mkdir {vfs}/dir1/sub1 {vfs}/dir1/sub2"], "verify": ["isdir {vfs}/dir1/sub1", "isdir {vfs}/dir1/sub2"]},
    {"id": "235", "description": "Snapshot then delete specific files", "setup": ["touch {vfs}/a {vfs}/b {vfs}/c {vfs}/d", "match printf snapshot > {vfs}/.vfsctl || true", "rm {vfs}/a {vfs}/c"], "verify": ["not exists {vfs}/a", "exists {vfs}/b", "not exists {vfs}/c", "exists {vfs}/d"]},
    {"id": "236", "description": "Snapshot then verify all md5s match originals", "setup": ["mkdir {vfs}/verify", "cp {src_pdf_small} {vfs}/verify/a", "cp {src_zip} {vfs}/verify/b", "cp {src_dmg} {vfs}/verify/c", "match printf snapshot > {vfs}/.vfsctl || true"], "verify": ["md5 {vfs}/verify/a == src_pdf_small", "md5 {vfs}/verify/b == src_zip", "md5 {vfs}/verify/c == src_dmg"]},
    {"id": "237", "description": "Snapshot then read 5MB file with python chunked read", "setup": ["python3 -c 'import sys; open(sys.argv[1],\"wb\").write(b\"x\"*5242880)' {vfs}/big", "match printf snapshot > {vfs}/.vfsctl || true", "python3 -c 'import sys; f=open(sys.argv[1],\"rb\"); print(len(f.read()))' {vfs}/big"], "verify": ["size {vfs}/big == 5242880"]},
    {"id": "238", "description": "Snapshot then mv dir with file, verify file path updated", "setup": ["mkdir {vfs}/a", "cp {src_pdf_small} {vfs}/a/f", "match printf snapshot > {vfs}/.vfsctl || true", "mv {vfs}/a {vfs}/b"], "verify": ["exists {vfs}/b/f", "md5 {vfs}/b/f == src_pdf_small"]},
    {"id": "239", "description": "Snapshot then sequential writes to same file", "setup": ["echo 1 > {vfs}/seq", "match printf snapshot > {vfs}/.vfsctl || true", "echo 2 > {vfs}/seq", "echo 3 > {vfs}/seq"], "verify": ["match test \"$(cat {vfs}/seq)\" = '3'"]},
    {"id": "240", "description": "Snapshot then create symlink (or copy if not supported)", "setup": ["cp {src_pdf_small} {vfs}/orig", "match printf snapshot > {vfs}/.vfsctl || true", "ln -s {vfs}/orig {vfs}/link 2>/dev/null || cp {src_pdf_small} {vfs}/link"], "verify": ["exists {vfs}/link"]},
    {"id": "241", "description": "Snapshot then verify root still readable", "setup": ["match printf snapshot > {vfs}/.vfsctl || true"], "verify": ["match test -d {vfs}/"]},
    {"id": "242", "description": "Snapshot then rename nested subdirs", "setup": ["mkdir -p {vfs}/p1/p2/p3", "match printf snapshot > {vfs}/.vfsctl || true", "mv {vfs}/p1/p2/p3 {vfs}/p1/p2/p3_renamed"], "verify": ["exists {vfs}/p1/p2/p3_renamed"]},
    {"id": "243", "description": "Snapshot then write to deeply nested file", "setup": ["mkdir -p {vfs}/a/b/c/d", "match printf snapshot > {vfs}/.vfsctl || true", "echo deep > {vfs}/a/b/c/d/file"], "verify": ["match test \"$(cat {vfs}/a/b/c/d/file)\" = 'deep'"]},
    {"id": "244", "description": "Create dir, snapshot, rename dir, verify content still there", "setup": ["mkdir {vfs}/d", "touch {vfs}/d/file", "match printf snapshot > {vfs}/.vfsctl || true", "mv {vfs}/d {vfs}/renamed"], "verify": ["exists {vfs}/renamed/file"]},
    {"id": "245", "description": "Snapshot then append across page boundary", "setup": ["python3 -c 'import sys; open(sys.argv[1],\"wb\").write(b\"a\"*8192)' {vfs}/p", "match printf snapshot > {vfs}/.vfsctl || true", "python3 -c 'import sys; open(sys.argv[1],\"ab\").write(b\"b\"*4096)' {vfs}/p"], "verify": ["size {vfs}/p == 12288"]},
    {"id": "246", "description": "Snapshot then mv same-name-file to different parent", "setup": ["touch {vfs}/root_file", "mkdir {vfs}/parent", "match printf snapshot > {vfs}/.vfsctl || true", "mv {vfs}/root_file {vfs}/parent/file"], "verify": ["not exists {vfs}/root_file", "exists {vfs}/parent/file"]},
    {"id": "247", "description": "Snapshot then verify all subdirs intact", "setup": ["mkdir -p {vfs}/d1/sub1 {vfs}/d2/sub2 {vfs}/d3/sub3", "match printf snapshot > {vfs}/.vfsctl || true", "touch {vfs}/d1/x {vfs}/d2/y {vfs}/d3/z"], "verify": ["count {vfs} == 3", "count {vfs}/d1 == 2", "count {vfs}/d2 == 2", "count {vfs}/d3 == 2"]},
    {"id": "248", "description": "Snapshot at file boundary, then create files", "setup": ["cp {src_pdf_small} {vfs}/boundary", "match printf snapshot > {vfs}/.vfsctl || true", "touch {vfs}/after1 {vfs}/after2"], "verify": ["exists {vfs}/boundary", "exists {vfs}/after1", "exists {vfs}/after2"]},
    {"id": "249", "description": "Snapshot, verify FUSE mount still responsive", "setup": ["match printf snapshot > {vfs}/.vfsctl || true"], "verify": ["match ls {vfs}/ | wc -l"]},
    {"id": "250", "description": "Final: snapshot multiple times, verify state preserved", "setup": ["echo first > {vfs}/s", "match printf snapshot > {vfs}/.vfsctl || true", "echo second > {vfs}/s", "match printf snapshot > {vfs}/.vfsctl || true", "echo third > {vfs}/s", "match printf snapshot > {vfs}/.vfsctl || true"], "verify": ["match test \"$(cat {vfs}/s)\" = 'third'"]}
  ]
}